#!/bin/sh
ROOT="$(git rev-parse --show-toplevel)"

# ── Main client checks ──
cd "$ROOT/online-proctoring/client" && npx lint-staged --no-stash 2>/dev/null; npx vitest run || { echo "❌ Main client tests failed"; exit 1; }

# ── Prototype checks ──
PROTO_DIR="$ROOT/online-proctoring/client-topics-prototype"
if [ -d "$PROTO_DIR" ]; then
  echo "🔍 Checking prototype CDN dependencies..."
  # Prototype must have KaTeX scripts for LaTeX rendering
  PROTO_KATEX=$(grep -cE "(katex\.min\.js|auto-render\.min\.js)" "$PROTO_DIR/index.html")
  if [ "$PROTO_KATEX" -lt 2 ]; then
    echo "❌ Prototype index.html is missing KaTeX scripts (has $PROTO_KATEX, need 2)"
    exit 1
  fi

  echo "🔍 Building prototype + checking test coverage..."
  cd "$PROTO_DIR"
  if [ -f "package.json" ]; then
    npm run lint 2>/dev/null || true
    npm run build 2>/dev/null || { echo "❌ Prototype build failed"; exit 1; }
    [ -f "tests/smoke.spec.ts" ] || { echo "❌ Missing tests/smoke.spec.ts"; exit 1; }
    [ -f "tests/visual.spec.ts" ] || { echo "❌ Missing tests/visual.spec.ts"; exit 1; }
    echo "✅ Prototype checks passed (CDN + Build + Test Coverage)"
  fi
fi
